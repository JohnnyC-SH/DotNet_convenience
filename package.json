{
  "name": "dotnet-convenience",
  "displayName": ".NET Convenience",
  "description": "%extension.description%",
  "version": "0.2.6",
  "publisher": "t1gr3ju4nmx",
  "icon": "images/icon.png",
  "license": "MIT",
  "sponsor": {
    "url": "https://paypal.me/SIPTecMX"
  },
  "author": {
    "name": "t1gr3ju4nmx",
    "url": "https://github.com/t1gr3ju4nmx"
  },
  "homepage": "https://github.com/t1gr3ju4nmx/DotNet_convenience#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/t1gr3ju4nmx/DotNet_convenience.git"
  },
  "bugs": {
    "url": "https://github.com/t1gr3ju4nmx/DotNet_convenience/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "keywords": ["dotnet", "csharp", "blazor", "aspnet", "maui", "controller"],
  "activationEvents": ["onStartupFinished"],
  "l10n": "./l10n",
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dotnetConv.addClass",
        "title": "%command.addClass%"
      },
      {
        "command": "dotnetConv.addRazorComponent",
        "title": "%command.addRazorComponent%"
      },
      {
        "command": "dotnetConv.addRazorPage",
        "title": "%command.addRazorPage%"
      },
      {
        "command": "dotnetConv.addInterface",
        "title": "%command.addInterface%"
      },
      {
        "command": "dotnetConv.addController",
        "title": "%command.addController%"
      },
      {
        "command": "dotnetConv.addProjectReference",
        "title": "%command.addProjectReference%"
      },
      {
        "command": "dotnetConv.newProjectInSolution",
        "title": "%command.newProjectInSolution%"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "dotnetConv.addClass",
          "group": "dotnetConv@1",
          "when": "resourceScheme == file && (explorerResourceIsFolder || resourceExtname == .cs || resourceExtname == .razor)"
        },
        {
          "command": "dotnetConv.addRazorComponent",
          "group": "dotnetConv@2",
          "when": "resourceScheme == file && (explorerResourceIsFolder || resourceExtname == .cs || resourceExtname == .razor)"
        },
        {
          "command": "dotnetConv.addRazorPage",
          "group": "dotnetConv@3",
          "when": "resourceScheme == file && (explorerResourceIsFolder || resourceExtname == .cs || resourceExtname == .razor)"
        },
        {
          "command": "dotnetConv.addInterface",
          "group": "dotnetConv@4",
          "when": "resourceScheme == file && (explorerResourceIsFolder || resourceExtname == .cs || resourceExtname == .razor)"
        },
        {
          "command": "dotnetConv.addController",
          "group": "dotnetConv@5",
          "when": "resourceScheme == file && (explorerResourceIsFolder || resourceExtname == .cs || resourceExtname == .razor)"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
